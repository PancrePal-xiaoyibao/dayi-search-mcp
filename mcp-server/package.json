{
  "name": "@xiaoyibao_2025/dayi-mcp-server",
  "version": "0.1.5",
  "description": "MCP server for querying Dayi medical search through a Python core",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "python",
    "README.md",
    "package.json"
  ],
  "bin": {
    "dayi-mcp": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PancrePal-xiaoyibao/dayi-search-mcp.git",
    "directory": "mcp-server"
  },
  "bugs": {
    "url": "https://github.com/PancrePal-xiaoyibao/dayi-search-mcp/issues"
  },
  "homepage": "https://github.com/PancrePal-xiaoyibao/dayi-search-mcp/tree/main/mcp-server",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dayi",
    "medical",
    "search"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "sync:python": "node scripts/sync-python-core.mjs",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run sync:python && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
